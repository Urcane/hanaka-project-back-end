# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hanaka_cake
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRY=86400

# CORS
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Store Info
STORE_NAME="Hanaka Cake"
STORE_ADDRESS="Jl. DR. Sukono Rt 09 No 11, Karang Rejo, Balikpapan Kota, Kalimantan Timur. 76124"
STORE_HOURS="07.00 AM - 11.00 PM"
STORE_WHATSAPP=6281299998888
STORE_INSTAGRAM=hanakacake.id

# Midtrans (QRIS) — only the Server Key is required for the Core API charge flow
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_QRIS_ACQUIRER=gopay
